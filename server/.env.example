# 语雀 API Token（v2 OpenAPI，必填）
YUQUE_TOKEN=your_token_here

# 语雀 API 基地址（可选，默认 https://www.yuque.com/api/v2）
# YUQUE_API_BASE=https://www.yuque.com/api/v2

# 回收站 Web API 认证（Cookie 登录态，使用回收站功能时必填）
# 获取方式：浏览器登录 yuque.com → F12 → Application → Cookies → 复制值
# YUQUE_COOKIE=_yuque_session=xxx; ...
# YUQUE_CTOKEN=xxx